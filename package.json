{
  "name": "tide-period-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm bundle:check",
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "build": "vite build",
    "bundle:check": "node scripts/checkBundleBudget.mjs",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "^7.0.5"
    }
  }
}
